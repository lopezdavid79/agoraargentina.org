<%- include('partials/header') %>

<main id="main-content" class="container py-5 text-center" role="main" aria-labelledby="error-title">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <h1 id="error-title" class="display-1 fw-bold text-danger mb-0">
                        <%= typeof status !== 'undefined' ? status : 500 %>
                    </h1>
                    <p class="lead text-muted mb-4">
                        <%= typeof message !== 'undefined' ? message : 'Error interno del servidor' %>
                    </p>
                    <a href="/" class="btn btn-primary btn-lg rounded-pill px-4" role="button">
                        Volver al inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
