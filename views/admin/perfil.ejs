<%- include('../partials/header.ejs') %>

<% if (typeof errores !== 'undefined' && errores) { %>
<div class="alert alert-danger alert-dismissible fade show mb-0 rounded-0 text-center fw-bold" role="alert" style="position: fixed; top: 0; left: 0; width: 100%; z-index: 9999;">
    <i class="fas fa-exclamation-circle me-2"></i><%= errores %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
</div>
<% } %>

<% if (typeof exito !== 'undefined' && exito) { %>
<div class="alert alert-success alert-dismissible fade show mb-0 rounded-0 text-center fw-bold" role="alert" style="position: fixed; top: 0; left: 0; width: 100%; z-index: 9999;">
    <i class="fas fa-check-circle me-2"></i><%= exito %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
</div>
<% } %>

<main id="main-content">
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh;">
        <div class="card p-4 shadow-lg" style="width: 100%; max-width: 480px;">

            <h2 class="text-center mb-1 fw-bold">Mi Perfil</h2>
            <p class="text-center text-muted mb-4">Usuario: <strong><%= user.username %></strong> &mdash; Rol: <span class="badge bg-warning text-dark"><%= user.rol %></span></p>

            <form action="/admin/perfil?_method=PUT" method="POST">

                <div class="mb-3">
                    <label for="nuevoUsername" class="form-label fw-bold">Nuevo nombre de usuario</label>
                    <input type="text" class="form-control" id="nuevoUsername" name="nuevoUsername"
                           value="<%= user.username %>" autocomplete="username">
                </div>

                <hr>

                <p class="text-muted small">Dejá los campos de contraseña en blanco si no querés cambiarla.</p>

                <div class="mb-3">
                    <label for="passwordActual" class="form-label fw-bold">Contraseña actual</label>
                    <input type="password" class="form-control" id="passwordActual" name="passwordActual"
                           placeholder="Ingresá tu contraseña actual" autocomplete="current-password">
                </div>

                <div class="mb-3">
                    <label for="passwordNueva" class="form-label fw-bold">Nueva contraseña</label>
                    <input type="password" class="form-control" id="passwordNueva" name="passwordNueva"
                           placeholder="Mínimo 6 caracteres" autocomplete="new-password">
                </div>

                <div class="mb-4">
                    <label for="passwordConfirmar" class="form-label fw-bold">Confirmar nueva contraseña</label>
                    <input type="password" class="form-control" id="passwordConfirmar" name="passwordConfirmar"
                           placeholder="Repetí la nueva contraseña" autocomplete="new-password">
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">Guardar cambios</button>
                    <a href="/admin/dashboard" class="btn btn-outline-secondary w-100">Cancelar</a>
                </div>

            </form>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
