<%- include('../../partials/header') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="Migas de pan" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Nueva Capacitación</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <h1 class="h2 fw-bold text-primary mb-4">Crear Nueva Capacitación</h1>
                    
                    <form action="/admin/capacitaciones/nuevo" method="POST">
                        
                        <div class="mb-3">
                            <label for="titulo" class="form-label fw-bold">Título de la Capacitación</label>
                            <input type="text" class="form-control" id="titulo" name="titulo" 
                                   placeholder="Ej: Uso de NVDA para oficina" required>
                        </div>

                        <div class="mb-3">
                            <label for="slug" class="form-label fw-bold">Slug (URL)</label>
                            <input type="text" class="form-control" id="slug" name="slug" 
                                   placeholder="ej: nvda-oficina" required>
                            <div class="form-text">Este nombre se usará en la dirección web del curso.</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="instructor" class="form-label fw-bold">Instructor</label>
                                <input type="text" class="form-control" id="instructor" name="instructor" 
                                       value="David Lopez" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="categoria" class="form-label fw-bold">Categoría</label>
                                <select class="form-select" id="categoria" name="categoria">
                                    <option value="Herramientas para el trabajo" selected>Herramientas para el trabajo</option>
                                    <option value="Accesibilidad Digital">Accesibilidad Digital</option>
                                    <option value="Autonomía">Autonomía</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="descripcion" class="form-label fw-bold">Descripción General</label>
                            <textarea class="form-control" id="descripcion" name="descripcion" rows="4" 
                                      placeholder="Explica de qué trata la capacitación..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="info" class="form-label fw-bold">información de las clase</label>
                            <textarea class="form-control" id="info" name="info" rows="4" 
                                      placeholder="Información de la clase ej:hora y días..."></textarea>
                        </div>


                        <div class="row bg-light p-3 rounded-3 mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label for="estado" class="form-label fw-bold">Estado Inicial</label>
                                <select class="form-select" id="estado" name="estado">
                                    <option value="Borrador" selected>Borrador</option>
                                    <option value="Activo">Activo (Publicar inmediatamente)</option>
                                                                        <option value="Activo">Terminado</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="privado" class="form-label fw-bold">Privacidad</label>
                                <select class="form-select" id="privado" name="privado">
                                    <option value="false" selected>Público</option>
                                    <option value="true">Privado (Solo con enlace)</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="link_vivo" class="form-label fw-bold">Enlace de Clase en Vivo (Zoom/Meet)</label>
                            <input type="url" class="form-control" id="link_vivo" name="link_vivo" 
                                   placeholder="https://zoom.us/j/...">
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="fas fa-save me-2"></i>Guardar Capacitación
                            </button>
                            <a href="/admin/dashboard" class="btn btn-outline-secondary">Cancelar</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>


<script>
    const tituloInput = document.getElementById('titulo');
    const slugInput = document.getElementById('slug');

    tituloInput.addEventListener('keyup', () => {
        // Solo autocompletamos si el campo slug está vacío o solo tiene el prefijo
        if (slugInput.value === '' || slugInput.value === 'nvda-para-') {
            const base = tituloInput.value.toLowerCase()
                .replace(/[^\w ]+/g, '')
                .replace(/ +/g, '-');
            
            // Si el título ya contiene "nvda", no repetimos el prefijo
            if (base.includes('nvda')) {
                slugInput.value = base;
            } else {
                slugInput.value = 'nvda-para-' + base;
            }
        }
    });
</script>