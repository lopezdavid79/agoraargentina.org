
<%- include('../../partials/header') %>

<main class="container py-5">
    <nav aria-label="Migas de pan" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/admin/capacitaciones/<%= idCap %>/modulos">Gestión de Módulos</a></li>
            <li class="breadcrumb-item active" aria-current="page">Editar Módulo</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 fw-bold text-primary mb-4">
                        <i class="fas fa-edit me-2"></i>Editar Módulo
                    </h1>

                    <form action="/admin/capacitaciones/<%= idCap %>/modulos/editar/<%= modulo.id %>" method="POST">
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label for="orden" class="form-label fw-bold">Orden</label>
                                <input type="number" class="form-control" id="orden" name="orden" 
                                       value="<%= modulo.orden %>" required>
                            </div>
                            <div class="col-md-8 mb-3">
                                <label for="tituloModulo" class="form-label fw-bold">Título del Módulo</label>
                                <input type="text" class="form-control" id="tituloModulo" name="tituloModulo" 
                                       value="<%= modulo.tituloModulo %>" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="descripcion" class="form-label fw-bold">Descripción / Temario</label>
                            <textarea class="form-control" id="descripcion" name="descripcion" rows="4"><%= modulo.descripcion %></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="linkMaterial" class="form-label fw-bold text-success">
                                <i class="fas fa-file-download me-1"></i> Link a Material (Drive/PDF)
                            </label>
                            <input type="url" class="form-control border-success-subtle" id="linkMaterial" 
                                   name="linkMaterial" value="<%= modulo.linkMaterial %>">
                        </div>

                        <div class="mb-4">
                            <label for="claseGrabada" class="form-label fw-bold text-primary">
                                <i class="fas fa-play-circle me-1"></i> Link a Grabación (YouTube)
                            </label>
                            <input type="url" class="form-control border-primary-subtle" id="claseGrabada" 
                                   name="claseGrabada" value="<%= modulo.claseGrabada %>">
                        </div>

    <div class="form-check form-switch mb-4">
    <input class="form-check-input" type="checkbox" role="switch" id="activo" name="activo" 
           <%= modulo.activo ? 'checked' : '' %>>
    <label class="form-check-label fw-bold" for="activo">
        <%= modulo.activo ? 'Módulo Habilitado' : 'Módulo Bloqueado (Oculto para alumnos)' %>
    </label>
</div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                                Guardar Cambios
                            </button>
                            <a href="/admin/capacitaciones/<%= idCap %>/modulos" class="btn btn-outline-secondary px-4 py-2" role="button">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../../partials/footer') %>