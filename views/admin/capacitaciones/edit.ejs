<%- include('../../partials/header') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="Migas de pan" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Editar: <%= cap.titulo %></li>
                </ol>
            </nav>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <h1 class="h2 fw-bold text-primary mb-4">Editar Capacitación</h1>
                    
                    <form action="/admin/capacitaciones/editar/<%= cap.id %>?_method=PUT" method="POST">
                        
                        <div class="mb-3">
                            <label for="titulo" class="form-label fw-bold">Título</label>
                            <input type="text" class="form-control" id="titulo" name="titulo" 
                                   value="<%= cap.titulo %>" required>
                        </div>

                        <div class="mb-3">
                            <label for="slug" class="form-label fw-bold">Slug (URL)</label>
                            <input type="text" class="form-control" id="slug" name="slug" 
                                   value="<%= cap.slug %>" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="instructor" class="form-label fw-bold">Instructor</label>
                                <input type="text" class="form-control" id="instructor" name="instructor" 
                                       value="<%= cap.instructor %>" required>
                            </div>
                            <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="infoClase" class="form-label fw-bold">Información de la clase</label>
                                <input type="text" class="form-control" id="infoClase" name="infoClase" 
                                       value="<%= cap.infoClase%>" required>
                            </div>
                        
                            <div class="col-md-6 mb-3">
                                <label for="categoria" class="form-label fw-bold">Categoría</label>
                                <select class="form-select" id="categoria" name="categoria">
                                    <option value="Herramientas para el trabajo" <%= cap.categoria === 'Herramientas para el trabajo' ? 'selected' : '' %>>Herramientas para el trabajo</option>
                                    <option value="Accesibilidad Digital" <%= cap.categoria === 'Accesibilidad Digital' ? 'selected' : '' %>>Accesibilidad Digital</option>
                                    <option value="Autonomía" <%= cap.categoria === 'Autonomía' ? 'selected' : '' %>>Autonomía</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="descripcion" class="form-label fw-bold">Descripción General</label>
                            <textarea class="form-control" id="descripcion" name="descripcion" rows="4"><%= cap.descripcion %></textarea>
                        </div>

                        <div class="row bg-light p-3 rounded-3 mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label for="estado" class="form-label fw-bold">Estado</label>
                                <select class="form-select" id="estado" name="estado">
                                    <option value="Borrador" <%= cap.estado === 'Borrador' ? 'selected' : '' %>>Borrador</option>
                                    <option value="activo" <%= cap.estado === 'activo' ? 'selected' : '' %>>Activo</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="privado" class="form-label fw-bold">Privacidad</label>
                                <select class="form-select" id="privado" name="privado">
                                    <option value="false" <%= cap.privado === 'false' || !cap.privado ? 'selected' : '' %>>Público</option>
                                    <option value="true" <%= cap.privado === 'true' ? 'selected' : '' %>>Privado</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="link_vivo" class="form-label fw-bold">Enlace de Clase en Vivo</label>
                            <input type="url" class="form-control" id="link_vivo" name="link_vivo" 
                                   value="<%= cap.link_vivo %>">
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                                <i class="fas fa-sync-alt me-2"></i>Actualizar Capacitación
                            </button>
                            <a href="/admin/dashboard" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>