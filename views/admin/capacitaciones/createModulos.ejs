<%- include('../../partials/header') %>

<div class="container py-5">
    <nav aria-label="Migas de pan" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Gestionar Contenido</li>
        </ol>
    </nav>

    <header class="mb-5">
        <h1 class="display-6 fw-bold text-primary">Gestionar Módulos</h1>
        <p class="text-muted">Agregue materiales y grabaciones a cada sesión de la capacitación.</p>
    </header>

    <div class="row">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-4"><i class="fas fa-plus-circle me-2"></i>Nuevo Módulo</h2>
                    
                    <form action="/admin/capacitaciones/<%= idCap %>/modulos/nuevo" method="POST">
                        
                        <div class="row">
                            <div class="col-4 mb-3">
                                <label for="orden" class="form-label fw-bold">Orden</label>
                                <input type="number" class="form-control" id="orden" name="orden" 
                                       value="<%= modulos.length + 1 %>" required>
                            </div>
                            <div class="col-8 mb-3">
                                <label for="tituloModulo" class="form-label fw-bold">Título</label>
                                <input type="text" class="form-control" id="tituloModulo" name="tituloModulo" 
                                       placeholder="Ej: Clase 1" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="descripcion" class="form-label fw-bold">Descripción / Temario</label>
                            <textarea class="form-control" id="descripcion" name="descripcion" rows="3" 
                                      placeholder="¿Qué se verá en esta sesión?"></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="linkMaterial" class="form-label fw-bold text-success">
                                <i class="fas fa-file-download me-1"></i> Link a Material (Drive/PDF)
                            </label>
                            <input type="url" class="form-control border-success-subtle" id="linkMaterial" 
                                   name="linkMaterial" placeholder="https://drive.google.com/...">
                        </div>

                        <div class="mb-4">
                            <label for="claseGrabada" class="form-label fw-bold text-primary">
                                <i class="fas fa-play-circle me-1"></i> Link a Grabación (YouTube)
                            </label>
                            <input type="url" class="form-control border-primary-subtle" id="claseGrabada" 
                                   name="claseGrabada" placeholder="https://youtube.com/...">
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm fw-bold">
                            Guardar Módulo
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-4">Módulos Cargados</h2>
                    
                    <% if (modulos && modulos.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th width="10%">#</th>
                                        <th width="60%">Título</th>
                                        <th width="30%">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% modulos.forEach(mod => { %>
                                        <tr>
                                            <td class="fw-bold"><%= mod.orden %></td>
                                            <td>
                                                <div class="fw-bold"><%= mod.tituloModulo %></div>
                                                <% if(mod.linkMaterial) { %>
                                                    <span class="badge bg-success-subtle text-success small">Material ok</span>
                                                <% } %>
                                            </td>
                                            <td>
    <% if (mod.activo) { %>
        <span class="badge bg-success"><i class="fas fa-eye me-1"></i> Visible</span>
    <% } else { %>
        <span class="badge bg-secondary"><i class="fas fa-eye-slash me-1"></i> Bloqueado</span>
    <% } %>
</td>
 
                                            <td>
                                                
<a href="/admin/capacitaciones/<%= idCap %>/modulos/editar/<%= mod.id %>" class="btn btn-sm btn-outline-primary" aria-label="Editar módulo: <%= mod.tituloModulo %>">
    <i class="fas fa-edit"></i>
</a>
<!-- eliminar modulo                                                 -->
<form action="/admin/capacitaciones/<%= idCap %>/modulos/eliminar/<%= mod.id %>?_method=DELETE" 
                                                      method="POST" onsubmit="return confirm('¿Eliminar este módulo?')">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar" aria-label="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="fas fa-folder-open fa-3x text-light mb-3"></i>
                            <p class="text-muted">Aún no hay módulos para esta capacitación.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>