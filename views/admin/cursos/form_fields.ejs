<%
const d = typeof datos !== 'undefined' ? datos : {};
%>

<div class="row">

    <!-- Título del Curso -->
    <div class="col-md-7 mb-3">
        <label for="titulo" class="form-label fw-bold text-primary">Título del Curso</label>
        <input type="text" class="form-control form-control-lg border-primary-subtle"
               id="titulo" name="titulo"
               value="<%= d.titulo || '' %>"
               placeholder="Ej: Word Accesible con NVDA"
               aria-required="true" required autofocus>
    </div>

    <!-- Slug -->
    <div class="col-md-5 mb-3">
        <label for="slug" class="form-label fw-bold text-muted">Slug (URL amigable)</label>
        <input type="text" class="form-control form-control-lg"
               id="slug" name="slug"
               value="<%= d.slug || '' %>"
               aria-describedby="slug-ayuda"
               aria-required="true" required>
        <div id="slug-ayuda" class="form-text">Se genera automáticamente desde el título. Puede editarlo.</div>
    </div>

</div><!-- /row -->

<div class="row mb-3">

    <!-- Modalidad -->
    <div class="col-md-6 mb-3">
        <label for="modalidad" class="form-label fw-bold">Modalidad</label>
        <select class="form-select" id="modalidad" name="modalidad" aria-required="true" required>
            <option value="" disabled <%= !d.modalidad ? 'selected' : '' %>>Seleccionar...</option>
            <option value="Online - Sincrónico"  <%= d.modalidad === 'Online - Sincrónico'  ? 'selected' : '' %>>Online - Sincrónico</option>
            <option value="Online - Asincrónico" <%= d.modalidad === 'Online - Asincrónico' ? 'selected' : '' %>>Online - Asincrónico</option>
            <option value="Presencial"           <%= d.modalidad === 'Presencial'           ? 'selected' : '' %>>Presencial</option>
            <option value="Híbrido"              <%= d.modalidad === 'Híbrido'              ? 'selected' : '' %>>Híbrido</option>
        </select>
    </div>

    <!-- Duración -->
    <div class="col-md-3 mb-3">
        <label for="duracion" class="form-label fw-bold">Duración</label>
        <input type="text" class="form-control" id="duracion" name="duracion"
               value="<%= d.duracion || '' %>" placeholder="Ej: 20 horas"
               aria-required="true" required>
    </div>

    <!-- URL Inscripción -->
    <div class="col-12 mb-3">
        <label for="urlInscrip" class="form-label fw-bold text-danger">URL de Formulario de Inscripción</label>
        <input type="url" class="form-control" id="urlInscrip" name="urlInscrip"
               value="<%= d.urlInscrip || '' %>"
               aria-required="true" required>
    </div>

    <!-- Objetivo General -->
    <div class="col-12 mb-3">
        <label for="objetivoGeneral" class="form-label fw-bold">Objetivo General</label>
        <textarea class="form-control" id="objetivoGeneral" name="objetivoGeneral"
                  rows="2" aria-required="true" required><%= d.objetivoGeneral || '' %></textarea>
    </div>

    <!-- Descripción Corta -->
    <div class="col-12 mb-3">
        <label for="descripcionCorta" class="form-label fw-bold">Descripción Corta (Resumen)</label>
        <textarea class="form-control" id="descripcionCorta" name="descripcionCorta"
                  rows="2" aria-required="true" required><%= d.descripcion || '' %></textarea>
    </div>

    <!-- Objetivos Específicos -->
    <div class="col-md-6 mb-3">
        <label for="objetivos" class="form-label fw-bold">Objetivos Específicos</label>
        <div id="objetivos-ayuda" class="form-text mb-1">Escribí uno por línea.</div>
        <textarea class="form-control" id="objetivos" name="objetivos"
                  rows="6" aria-describedby="objetivos-ayuda"><%= d.objetivosText || '' %></textarea>
    </div>

    <!-- Temario -->
    <div class="col-md-6 mb-3">
        <label for="temario" class="form-label fw-bold">Temario</label>
        <div id="temario-ayuda" class="form-text mb-1">Escribí uno por línea.</div>
        <textarea class="form-control" id="temario" name="temario"
                  rows="6" aria-describedby="temario-ayuda"><%= d.temarioText || '' %></textarea>
    </div>

</div><!-- /row -->

<!-- Gestión de Imagen -->
<div class="row align-items-center bg-light p-3 rounded-3 border mb-3">

    <div class="col-md-8">
        <label for="imagen" class="form-label fw-bold">Ruta de la Imagen</label>
        <input type="text" class="form-control mb-2" id="imagen" name="imagen"
               value="<%= d.imagen || '' %>" placeholder="Ej: /curso-nvda.webp"
               aria-describedby="imagen-ayuda"
               aria-required="true" required>
        <div id="imagen-ayuda" class="form-text mb-2">Ingresá la ruta relativa o URL de la imagen.</div>

        <label for="alt" class="form-label fw-bold">Texto Alternativo (Accesibilidad)</label>
        <textarea class="form-control" id="alt" name="alt" rows="2"
                  placeholder="Describe la imagen para personas con discapacidad visual..."
                  aria-required="true" required><%= d.alt || '' %></textarea>
    </div>

    <div class="col-md-4 text-center">
        <div id="preview-container"
             class="border rounded bg-white d-flex align-items-center justify-content-center"
             style="height: 120px; overflow: hidden;"
             aria-hidden="true">
            <img id="img-preview"
                 src="<%= d.imagen || '' %>"
                 class="img-fluid <%= d.imagen ? '' : 'd-none' %>"
                 alt="">
            <p id="preview-text" class="text-muted small <%= d.imagen ? 'd-none' : '' %>">Sin vista previa</p>
        </div>
    </div>

</div><!-- /row imagen -->

<script>
(function iniciarForm() {
    var tituloEl  = document.getElementById('titulo');
    var slugEl    = document.getElementById('slug');
    var imagenEl  = document.getElementById('imagen');
    var previewEl = document.getElementById('img-preview');
    var preTextEl = document.getElementById('preview-text');

    // Reintenta si el DOM no está listo aún (partial cargado post DOMContentLoaded)
    if (!tituloEl || !slugEl) {
        setTimeout(iniciarForm, 0);
        return;
    }

    function generarSlug(texto) {
        return texto
            .toLowerCase()
            .trim()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-+|-+$/g, '');
    }

    var slugManual = slugEl.value !== '';

    slugEl.addEventListener('input', function () {
        slugManual = true;
    });

    tituloEl.addEventListener('input', function () {
        if (!slugManual) {
            slugEl.value = generarSlug(tituloEl.value);
        }
    });

    if (!slugEl.value && tituloEl.value) {
        slugEl.value = generarSlug(tituloEl.value);
    }

    // Previsualización de imagen
    if (imagenEl && previewEl) {
        imagenEl.addEventListener('input', function () {
            var url = imagenEl.value.trim();
            if (url) {
                previewEl.src = url;
                previewEl.classList.remove('d-none');
                if (preTextEl) preTextEl.classList.add('d-none');
            } else {
                previewEl.src = '';
                previewEl.classList.add('d-none');
                if (preTextEl) preTextEl.classList.remove('d-none');
            }
        });
    }
})();
</script>

<script>
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.modal').forEach(function (modal) {
        modal.addEventListener('hidden.bs.modal', function () {
            var formulario = modal.querySelector('form');
            if (!formulario) return;

            formulario.reset();

            var slugInput = formulario.querySelector('#slug');
            if (slugInput) slugInput.value = '';

            var previewImg  = formulario.querySelector('#img-preview');
            var previewText = formulario.querySelector('#preview-text');
            if (previewImg)  { previewImg.src = ''; previewImg.classList.add('d-none'); }
            if (previewText) { previewText.classList.remove('d-none'); }
        });
    });
});
</script>
