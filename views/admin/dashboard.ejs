<%- include('../partials/header') %>

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-5 fw-bold text-primary">Panel de Administración</h1>
            <p class="lead text-muted">Gestiona el contenido de Ágora Argentina desde un solo lugar.</p>
            
            <div class="d-flex justify-content-center gap-3 mt-4">
                <% if (user.rol !== 'instructor') { %>
                    <a href="/admin/noticias/nuevo" class="btn btn-primary btn-lg px-4 shadow-sm">
                        <i class="fas fa-plus-circle me-2"></i>Nueva Noticia
                    </a>
                    <a href="/admin/cursos/nuevo" class="btn btn-success btn-lg px-4 shadow-sm">
                        <i class="fas fa-graduation-cap me-2"></i>Nuevo Curso
                    </a>
                <% } %>
                <a href="/admin/capacitaciones/nuevo" class="btn btn-warning btn-lg px-4 shadow-sm">
                    <i class="fas fa-plus-circle me-2"></i>Nueva Capacitación
                </a>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4 border-0" id="adminTabs" role="tablist">
        <% if (user.rol !== 'instructor') { %>
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold border-0" id="noticias-tab" data-bs-toggle="tab" data-bs-target="#noticias" type="button" role="tab" aria-controls="noticias" aria-selected="true">
                    <i class="fas fa-newspaper me-2 text-primary"></i>Gestión de Noticias
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold border-0" id="cursos-tab" data-bs-toggle="tab" data-bs-target="#cursos" type="button" role="tab" aria-controls="cursos" aria-selected="false">
                    <i class="fas fa-book-reader me-2 text-success"></i>Gestión de Cursos
                </button>
            </li>
        <% } %>
        
        <li class="nav-item" role="presentation">
            <button class="nav-link <%= user.rol === 'instructor' ? 'active' : '' %> fw-bold border-0" id="capacitaciones-tab" data-bs-toggle="tab" data-bs-target="#capacitaciones" type="button" role="tab" aria-controls="capacitaciones" aria-selected="<%= user.rol === 'instructor' ? 'true' : 'false' %>">
                <i class="fas fa-chalkboard-teacher me-2 text-warning"></i>Gestión de Capacitaciones
            </button>
        </li>
    </ul>

    <div class="tab-content" id="adminTabsContent">
        
        <% if (user.rol !== 'instructor') { %>
            <div class="tab-pane fade show active" id="noticias" role="tabpanel" aria-labelledby="noticias-tab">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Título</th>
                                        <th>Fecha</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% noticias.forEach(noticia => { %>
                                        <tr>
                                            <td class="ps-4 fw-bold"><%= noticia.titulo %></td>
                                            <td><%= noticia.fecha %></td>
                                            <td class="text-center">
                                                <div class="btn-group shadow-sm">
                                                    <a href="/admin/noticias/editar/<%= noticia.id %>" class="btn btn-sm btn-outline-primary" aria-label="Editar noticia">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form action="/admin/noticias/eliminar/<%= noticia.id %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Eliminar noticia?')">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Eliminar noticia">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="cursos" role="tabpanel" aria-labelledby="cursos-tab">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Curso</th>
                                        <th>Categoría</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% cursos.forEach(curso => { %>
                                        <tr>
                                            <td class="ps-4 fw-bold"><%= curso.titulo %></td>
                                            <td><%= curso.categoria %></td>
                                            <td class="text-center">
                                                <div class="btn-group shadow-sm">
                                                    <a href="/admin/cursos/editar/<%= curso.id %>" class="btn btn-sm btn-outline-success" aria-label="Editar curso">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <div class="tab-pane fade <%= user.rol === 'instructor' ? 'show active' : '' %>" id="capacitaciones" role="tabpanel" aria-labelledby="capacitaciones-tab">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Capacitación</th>
                                    <th>Instructor</th>
                                    <th>Estado</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% capacitaciones.forEach(cap => { %>
                                    <tr>
                                        <td class="ps-4">
                                            <span class="fw-bold text-dark"><%= cap.titulo %></span>
                                            <br><small class="text-muted"><%= cap.categoria %></small>
                                        </td>
                                        <td><%= cap.instructor %></td>
                                        <td>
                                            <span class="badge rounded-pill <%= cap.estado === 'activo' ? 'bg-success' : 'bg-secondary' %>">
                                                <%= cap.estado %>
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group shadow-sm">
                                                <a href="/admin/capacitaciones/<%= cap.id %>/modulos" class="btn btn-sm btn-outline-warning" title="Gestionar Módulos" aria-label="Gestionar módulos de <%= cap.titulo %>">
                                                    <i class="fas fa-list-ol"></i>
                                                </a>
                                                <a href="/admin/capacitaciones/editar/<%= cap.id %>" class="btn btn-sm btn-outline-primary" aria-label="Editar capacitación">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form action="/admin/capacitaciones/eliminar/<%= cap.id %>?_method=DELETE" method="POST" onsubmit="return confirm('¿Eliminar capacitación?')">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Eliminar capacitación">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    body { background-color: #f8f9fa; font-family: 'Segoe UI', sans-serif; }
    .nav-tabs .nav-link { color: #6c757d; padding: 1rem 1.5rem; transition: 0.3s; cursor: pointer; border: none !important; }
    .nav-tabs .nav-link.active { color: #0d6efd !important; border-bottom: 3px solid #0d6efd !important; background: none; }
    .nav-tabs .nav-link:hover { background-color: rgba(13, 110, 253, 0.05); }
    .rounded-4 { border-radius: 1rem !important; }
    .btn-group form { display: inline; }
</style>

<%- include('../partials/footer') %>