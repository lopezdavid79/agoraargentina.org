<% 
    const d = typeof datos !== 'undefined' ? datos : {}; 
    const idP = typeof idPrefijo !== 'undefined' && idPrefijo ? '-' + idPrefijo : '';
%>

<div class="row">
    <div class="col-md-7 mb-3">
        <label for="titulo<%= idP %>" class="form-label fw-bold">Título de la noticia</label>
        <input type="text" class="form-control form-control-lg" 
               id="titulo<%= idP %>" name="titulo" 
               value="<%= d.titulo || '' %>" 
               placeholder="Ej: Gran avance en el Programa Ágora" required autofocus>
    </div>

    <div class="col-md-5 mb-3">
        <label for="slug<%= idP %>" class="form-label fw-bold text-muted">Slug (Enlace URL)</label>
        <input type="text" class="form-control form-control-lg" 
               id="slug<%= idP %>" name="slug" 
               value="<%= d.slug || '' %>"
               
               required>
        <!-- <div class="form-text">Se genera desde el título. Podés editarlo manualmente.</div> -->
    </div>
</div>

<div class="mb-3">
    <label for="copete<%= idP %>" class="form-label fw-bold">Copete (Resumen corto)</label>
    <textarea class="form-control" id="copete<%= idP %>" name="copete" rows="2" 
              placeholder="Un breve resumen que aparecerá en el listado..." required><%= d.copete || '' %></textarea>
</div>

<div class="row align-items-center mb-3 p-3 bg-light rounded border">
    <div class="col-md-8">
        <label for="imagenUrl<%= idP %>" class="form-label fw-bold">Imagen de la Noticia</label>
        <input type="file" class="form-control mb-1" id="imagenUrl<%= idP %>" name="imagenUrl"
               accept="image/jpeg,image/png,image/webp"
               aria-describedby="imagenUrl-ayuda<%= idP %>">
        <div id="imagenUrl-ayuda<%= idP %>" class="form-text mb-2">JPEG, PNG o WebP. Máximo 5MB.</div>
        <input type="hidden" name="imagenUrl" value="<%= d.imagenUrl || '' %>" aria-hidden="true">
        
        <label for="alt<%= idP %>" class="form-label fw-bold text-success">Texto Alternativo (Accesibilidad)</label>
        <input type="text" class="form-control" id="alt<%= idP %>" name="alt" 
               value="<%= d.alt || '' %>" 
               placeholder="Describe la imagen para personas con discapacidad visual" required>
        <div class="form-text">Ej: "Persona utilizando una computadora con el lector de pantalla NVDA".</div>
    </div>
    
    <div class="col-md-4 text-center">
        <div id="preview-container<%= idP %>" class="mt-2 border rounded d-flex align-items-center justify-content-center bg-white" style="height: 120px; overflow: hidden;" aria-hidden="true">
            <img id="img-preview<%= idP %>" src="<%= d.imagenUrl || '' %>" 
                 alt="<%= d.alt || 'Previsualización' %>" 
                 class="img-fluid <%= d.imagenUrl ? '' : 'd-none' %>">
            <small id="preview-text<%= idP %>" class="text-muted <%= d.imagenUrl ? 'd-none' : '' %>">Vista previa</small>
        </div>
    </div>
</div>

<% if (d.fecha) { %>
<div class="mb-3 form-check">
    <input type="checkbox" class="form-check-input" id="actualizarFecha<%= idP %>" name="actualizarFecha">
    <label class="form-check-label" for="actualizarFecha<%= idP %>">Actualizar fecha de publicación a hoy</label>
    <div class="form-text">Fecha actual: <strong><%= d.fecha %></strong>. Si marcás esta opción, se cambiará a la fecha de hoy.</div>
</div>
<% } %>

<div class="mb-4">
    <label for="contenido<%= idP %>" class="form-label fw-bold">Contenido Principal</label>
    <textarea class="form-control" id="contenido<%= idP %>" name="contenido" rows="10" 
              placeholder="Escribe aquí toda la noticia..." required><%= d.contenido || '' %></textarea>
    <div class="form-text">El sistema respetará tus párrafos y saltos de línea.</div>
</div>


<script>
(function iniciarFormNoticias() {
    // Buscar dentro del script actual, no en todo el document
    var scripts = document.querySelectorAll('script');
    var thisScript = scripts[scripts.length - 1];
    var container = thisScript.closest('.modal, form') || document;

    var tituloIn = container.querySelector('[name="titulo"]');
    var slugIn   = container.querySelector('[name="slug"]');
    var imgIn    = container.querySelector('[name="imagenUrl"]');
    var altIn    = container.querySelector('[name="alt"]');
    var preview  = container.querySelector('#img-preview<%= idP %>');
    var preText  = container.querySelector('#preview-text<%= idP %>');

    if (!tituloIn || !slugIn) {
        setTimeout(iniciarFormNoticias, 0);
        return;
    }

    function generarSlug(texto) {
        return texto
            .toLowerCase().trim()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-+|-+$/g, '');
    }

    var slugEditadoManualmente = slugIn.value !== '';

    slugIn.addEventListener('input', function () {
        slugEditadoManualmente = true;
    });

    tituloIn.addEventListener('input', function () {
        if (!slugEditadoManualmente) {
            slugIn.value = generarSlug(tituloIn.value);
        }
    });

    if (!slugIn.value && tituloIn.value) {
        slugIn.value = generarSlug(tituloIn.value);
    }

    if (imgIn && preview) {
        imgIn.addEventListener('change', function () {
            if (imgIn.files && imgIn.files[0]) {
                preview.src = URL.createObjectURL(imgIn.files[0]);
                preview.classList.remove('d-none');
                if (preText) preText.classList.add('d-none');
            } else {
                preview.src = '';
                preview.classList.add('d-none');
                if (preText) preText.classList.remove('d-none');
            }
        });
    }

    if (altIn && preview) {
        altIn.addEventListener('input', function () { preview.alt = altIn.value; });
    }
})();
</script>