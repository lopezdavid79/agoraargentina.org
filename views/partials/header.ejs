<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>
        <%= typeof title !== 'undefined' ? title + ' | ' : '' %> 
        Programa Ágora Argentina | Inclusión Laboral para Personas con Discapacidad Visual
    </title>
    <meta name="keywords" content="discapacidad visual, inclusión laboral, empleo argentina, programa ágora, accesibilidad, talento diverso">
    <meta name="author" content="Ágora Argentina">
    <meta name="robots" content="index, follow">

    <link rel="canonical" href="<%= typeof pageUrl !== 'undefined' ? pageUrl : 'https://agoraargentina.ar/' %>">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Programa Ágora Argentina",
        "url": "https://agoraargentina.ar/",
        "description": "Inclusión laboral para personas con discapacidad visual",
        "areaServed": "Argentina"
    }
    </script>

    <meta property="og:type" content="website">
    <meta property="og:url" content="https://agoraargentina.ar/">
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Programa Ágora' %>">
    <meta property="og:description" content="<%= typeof noticia !== 'undefined' ? noticia.copete : 'Novedades sobre inclusión laboral.' %>">
    <% if (typeof noticia !== 'undefined' && noticia.imagenUrl) { %>
        <meta property="og:image" content="<%= noticia.imagenUrl %>">
    <% } %>
    <meta name="description" content="Mejora tus oportunidades de acceso al mercado laboral. Cursos, capacitación e intermediación laboral para personas ciegas y con baja visión.">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css"> 
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <a href="#main-content" class="skip-link btn btn-lg btn-secondary" role="button">Ir al contenido principal</a>

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm border-bottom" aria-label="Navegación Principal del Sitio">
            <div class="container-fluid">

                <a class="navbar-brand text-dark fw-bold fs-4 d-flex align-items-center" href="/">
                    <img src="https://agoraargentina.ar/agora20-asaerca.png" 
                         alt="Logos Programa Ágora 20 años y ASAERCA" 
                         style="height: 140px; width: auto;" 
                         class="d-inline-block align-text-top me-2">
                    <span class="d-none d-sm-inline text-primary">Programa Ágora Argentina</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="abrir Menú">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto" role="menubar">

                        <li class="nav-item"><a class="nav-link text-dark fw-bold mx-2" href="/">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-bold mx-2" href="/quienes-somos">Quiénes Somos</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-bold mx-2" href="/servicios">Servicios</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-bold mx-2" href="/cursos">Capacitaciones y cursos</a></li>
                        <li class="nav-item"><a class="nav-link text-dark fw-bold mx-2" href="/noticias">Noticias</a></li>

                        
                    </ul>
                </div>

            </div>
        </nav>
    </header>
